# =============================================================================
# .env.example — AutoLab Variables de Entorno
# =============================================================================
# Copiar a .env y rellenar con valores reales.
# NUNCA commitear .env al repositorio.
# =============================================================================


# -----------------------------------------------------------------------------
# NVIDIA API — Free Developer Tier (45 RPM)
# Obtener en: https://build.nvidia.com/
# -----------------------------------------------------------------------------
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------------
# Brave Search API — Free Tier (2000 búsquedas/mes)
# Obtener en: https://api.search.brave.com/
# -----------------------------------------------------------------------------
BRAVE_SEARCH_API_KEY=BSA-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------------
# PostgreSQL / Supabase
# Si usás Supabase self-hosted en Coolify: usar la URL de conexión directa
# Formato: postgresql://postgres:password@host:5432/postgres
# -----------------------------------------------------------------------------
SUPABASE_DB_URL=postgresql://postgres:TU_PASSWORD@localhost:5432/postgres

# Supabase API (para n8n y Claude Desktop MCP)
SUPABASE_URL=http://tu-servidor:8000
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# -----------------------------------------------------------------------------
# Paths dentro del contenedor autolab-api
# Ajustar según el mount point en docker-compose.yml
# -----------------------------------------------------------------------------
SQLITE_DB_PATH=/app/data/coco_lab.db
SCRIPTS_PATH=/app/scripts


# -----------------------------------------------------------------------------
# autolab-api
# -----------------------------------------------------------------------------
AUTOLAB_API_PORT=8000
AUTOLAB_API_URL=http://autolab-api:8000  # URL interna de Docker (desde n8n)

# Para acceso externo (Claude Code desde tu Mac local):
AUTOLAB_API_EXTERNAL_URL=http://TU_SERVIDOR_IP:8000


# -----------------------------------------------------------------------------
# n8n
# -----------------------------------------------------------------------------
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CAMBIAR_PASSWORD_SEGURO
N8N_ENCRYPTION_KEY=GENERAR_CON_openssl_rand_hex_32

# Timezone para los cron jobs de n8n
GENERIC_TIMEZONE=America/Argentina/Mendoza


# -----------------------------------------------------------------------------
# Configuración del loop autónomo
# -----------------------------------------------------------------------------
AUTOLAB_DEFAULT_CYCLES=50
AUTOLAB_DEFAULT_JOBS_PER_CYCLE=10
AUTOLAB_BENCHMARK_FITNESS=1.193  # V5 Portfolio — actualizar con cada nuevo campeón
